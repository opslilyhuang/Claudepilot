{
  "name": "claudepilot",
  "productName": "ClaudePilot",
  "version": "1.0.0",
  "description": "Claude Code 桌面客户端 - AI 编程助手",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-rebuild",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["claude", "ai", "coding", "assistant"],
  "author": "Julian Huang",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "better-sqlite3": "^12.6.2",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  },
  "type": "commonjs",
  "build": {
    "appId": "com.claudepilot.app",
    "productName": "ClaudePilot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "index.html",
      "icon.png",
      "bridge/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "identity": null,
      "target": [
        {
          "target": "dir",
          "arch": ["arm64"]
        }
      ]
    },
    "win": {
      "icon": "icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "icon": "icon.png",
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
